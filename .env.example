# Copia este archivo a .env (cp .env.example .env) — no hace falta cambiar
# nada para levantar el stack local, estos valores ya coinciden con las
# credenciales hardcodeadas en docker-compose.yaml para el Postgres local
# de desarrollo (no son secretos reales, es un entorno local/sintético).

AIRFLOW_UID=50000

# Postgres del DWH (oxxo_cx_intelligence) — servicio postgres-oxxo en
# docker-compose.yaml. DB_USER/DB_PASSWORD deben coincidir con
# POSTGRES_USER/POSTGRES_PASSWORD del servicio postgres-oxxo en ese archivo.
DB_HOST=postgres-oxxo
DB_PORT=5432
DB_NAME=oxxo_cx_intelligence
DB_USER=airflow
DB_PASSWORD=airflow
